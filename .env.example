# =============================================================================
# Standalone Tractus-X EDC — environment variables
#
# Copy this file to .env and fill in the dataspace-specific values, OR use
#   ./scripts/setup.sh hanka
# which copies presets/hanka.env.example, generates strong random secrets, and
# leaves only the dataspace-issued fields for you to fill in.
# =============================================================================

# --- EDC version ---
EDC_VERSION=0.12.0

# --- Public hostname (HTTPS, fronted by Caddy) -------------------------------
# DNS A record must already resolve to this host's public IP — otherwise
# Caddy can't complete the Let's Encrypt HTTP-01 challenge.
EDC_PUBLIC_HOST=

# Email used for the Let's Encrypt account.
ACME_EMAIL=

# --- Participant identity (issued by the dataspace operator) -----------------
EDC_BPN=
EDC_DID=

# --- Participant context ID (UUID, mandatory since EDC 0.12.0) --------------
# A URL-path-safe identifier that the EDC uses internally as a tenant key.
# Generate with: uuidgen   (or:  python -c 'import uuid;print(uuid.uuid4())')
EDC_PARTICIPANT_CONTEXT_ID=

# --- DSP / data-plane URLs advertised to peers (HTTPS via Caddy) -------------
# Once EDC_PUBLIC_HOST is set, these usually become:
#   EDC_DSP_CALLBACK_ADDRESS=https://${EDC_PUBLIC_HOST}/api/v1/dsp
#   EDC_DATAPLANE_PUBLIC_URL=https://${EDC_PUBLIC_HOST}/api/public
EDC_DSP_CALLBACK_ADDRESS=
EDC_DATAPLANE_PUBLIC_URL=

# Internal hostname inside the docker network. Leave as-is.
EDC_HOSTNAME=controlplane

# --- Dataspace operator endpoints --------------------------------------------
STS_TOKEN_URL=
CREDENTIAL_SERVICE_URL=
BDRS_URL=
TRUSTED_ISSUER_DID=

# --- Secrets ----------------------------------------------------------------
# Provided by the dataspace operator at onboarding:
STS_CLIENT_SECRET=

# Data-plane signer key. Leave EMPTY (recommended): the stack generates an
# Ed25519 keypair locally on first boot and keeps it in vault — nothing
# outside this host ever needs it, exactly like a managed-wallet dataspace
# (Cofinity-X). Only set this to bring your own key (a private Ed25519 JWK).
TOKEN_SIGNER_KEY_JWK=

# --- Local infrastructure ---------------------------------------------------
POSTGRES_USER=edc
# setup.sh generates a strong random value here on first run
POSTGRES_PASSWORD=

# Management API key (HTTP header X-Api-Key). setup.sh generates a strong
# random value here. The management API only listens on 127.0.0.1.
EDC_API_KEY=

# --- Vault token lifetime ---------------------------------------------------
# How long an EDC vault token is valid before vault-init mints a fresh one.
# The EDC auto-renews the token while it is running, so this is essentially
# the maximum the EDC can stay stopped without losing its token.
EDC_TOKEN_PERIOD=720h

# --- Host port mappings ------------------------------------------------------
# Management API. Bound to 127.0.0.1 only.
EDC_MANAGEMENT_HOST_PORT=29181

# --- Java tuning ------------------------------------------------------------
JAVA_TOOL_OPTIONS=-Xmx512m

# --- Observability ----------------------------------------------------------
# The tractusx/edc-* images bundle the OpenTelemetry javaagent and default its
# exporter to localhost:4318. This stack ships no collector, so leave the agent
# off (avoids endless export errors that also swallow the EDC app logs). Set to
# true only if you also run an OTLP collector.
OTEL_JAVAAGENT_ENABLED=false
