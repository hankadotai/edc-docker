# =============================================================================
# Standalone Tractus-X EDC — environment variables (generic template)
#
# Copy this file to .env and fill in the dataspace-specific values, OR use
#   ./scripts/setup.sh hanka
# which copies presets/hanka.env.example, generates strong random secrets, and
# leaves only the dataspace-issued fields for you to fill in.
#
# Everything not listed under the required sections has a working default in
# docker-compose.yaml — see "Optional overrides" at the bottom.
# =============================================================================

# --- Your deployment ---
# Public hostname for this connector. The DNS A/AAAA record must already
# resolve to this host's public IP — otherwise Caddy can't complete the
# Let's Encrypt HTTP-01 challenge.
EDC_PUBLIC_HOST=
# Let's Encrypt notification email — used only by the bundled Caddy. Leave
# empty if you terminate TLS at your own proxy (ONBOARDING §4).
ACME_EMAIL=

# --- Participant identity (issued by the dataspace operator) ---
EDC_BPN=
EDC_DID=

# --- Participant context ID (UUID, mandatory since EDC 0.12.0) ---
# setup.sh generates this. Manual: uuidgen
EDC_PARTICIPANT_CONTEXT_ID=

# --- Dataspace operator endpoints ---
STS_TOKEN_URL=
# Usually contains base64 of your BPN — KEEP the '=' padding:
#   echo -n "$EDC_BPN" | base64
CREDENTIAL_SERVICE_URL=
BDRS_URL=
TRUSTED_ISSUER_DID=

# --- Secrets ---
# Provided by the dataspace operator at onboarding:
STS_CLIENT_SECRET=
# setup.sh fills these two with strong random values. The management API
# (X-Api-Key header) only listens on 127.0.0.1.
POSTGRES_PASSWORD=
EDC_API_KEY=

# --- Optional overrides (defaults live in docker-compose.yaml) ---------------
# Data-plane signer key: leave unset (recommended) — the stack generates an
# Ed25519 keypair locally on first boot and keeps it in vault; nothing outside
# this host ever needs it, exactly like a managed-wallet dataspace. Only set
# to bring your own private Ed25519 JWK (ONBOARDING §1.2).
#TOKEN_SIGNER_KEY_JWK=
# Public URLs advertised to peers — derived from EDC_PUBLIC_HOST; override
# only if your edge routes them somewhere non-standard.
#EDC_DSP_CALLBACK_ADDRESS=https://<host>/api/v1/dsp
#EDC_DATAPLANE_PUBLIC_URL=https://<host>/api/public
# EDC image tag.
#EDC_VERSION=0.12.0
#POSTGRES_USER=edc
# Vault-token lifetime = the longest the EDC can stay stopped without losing
# its vault token (auto-renewed while running; re-minted by up.sh if expired).
#EDC_TOKEN_PERIOD=720h
# Host port for the management API (127.0.0.1 only).
#EDC_MANAGEMENT_HOST_PORT=29181
#JAVA_TOOL_OPTIONS=-Xmx512m
# The tractusx images bundle an OTel javaagent defaulting to localhost:4318;
# this stack ships no collector, so it stays off unless you run one.
#OTEL_JAVAAGENT_ENABLED=false
