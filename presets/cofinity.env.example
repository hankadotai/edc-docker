# =============================================================================
# Cofinity-X — preset
#
# All endpoints below are placeholders. The dataspace operator provisions the
# exact URLs when they onboard your participant — check your onboarding email
# for the values for your tenant and environment (INT / STABLE / PROD).
#
# Onboarding produces:
#   - your BPN
#   - your DID
#   - your STS client secret
#   - the trusted issuer DID for the environment
#
# Everything else — ports, image versions, JVM sizing, the DSP / data-plane
# URLs advertised to peers — has working defaults. See "Optional overrides"
# at the bottom.
# =============================================================================

# --- Your deployment ---
# Public hostname for this connector (the DNS record must point at this host).
EDC_PUBLIC_HOST=
# Let's Encrypt notification email — used only by the bundled Caddy. Leave
# empty if you terminate TLS at your own proxy (ONBOARDING §4).
ACME_EMAIL=

# --- Identity (provided by onboarding) ---
EDC_BPN=
EDC_DID=

# --- Participant context ID (setup.sh generates this) ---
EDC_PARTICIPANT_CONTEXT_ID=

# --- Operator endpoints (REPLACE WITH ONBOARDING VALUES) ---
STS_TOKEN_URL=https://<sts-host>/api/sts/token
# <BASE64_BPN> = base64 of your BPN, WITH '=' padding:
#   echo -n "$EDC_BPN" | base64
CREDENTIAL_SERVICE_URL=https://<wallet-host>/api/credentials/v1/participants/<BASE64_BPN>
BDRS_URL=https://<bdrs-host>/api/directory
TRUSTED_ISSUER_DID=did:web:<issuer-host>:<ISSUER_BPN>

# --- Secrets ---
# OAuth client secret provided by onboarding.
STS_CLIENT_SECRET=
# setup.sh fills these two with strong random values.
POSTGRES_PASSWORD=
EDC_API_KEY=

# --- Optional overrides (defaults live in docker-compose.yaml) ---------------
# Data-plane signer key: self-generated in vault on first boot (Cofinity-X
# does not hand out signer keys); only set to bring your own private
# Ed25519 JWK (ONBOARDING §1.2).
#TOKEN_SIGNER_KEY_JWK=
# Public URLs advertised to peers — derived from EDC_PUBLIC_HOST; override
# only if your edge routes them somewhere non-standard.
#EDC_DSP_CALLBACK_ADDRESS=https://<host>/api/v1/dsp
#EDC_DATAPLANE_PUBLIC_URL=https://<host>/api/public
#EDC_VERSION=0.12.0
#POSTGRES_USER=edc
#EDC_TOKEN_PERIOD=720h
#EDC_MANAGEMENT_HOST_PORT=29181
#JAVA_TOOL_OPTIONS=-Xmx512m
#OTEL_JAVAAGENT_ENABLED=false
