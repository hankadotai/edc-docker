# =============================================================================
# Preset: Hanka  —  https://hanka.ai
#
# This is the default preset. Hanka operates the dataspace, so the only moving
# parts on your side are this Compose stack and a public hostname.
#
# Onboarding (https://hanka.ai) produces these values, which you fill in below:
#   EDC_BPN                       operator-assigned BPN
#   EDC_DID                       DID for your participant
#   STS_CLIENT_SECRET             returned when the participant context is created
#   TOKEN_SIGNER_KEY_JWK          data-plane signer private JWK — returned
#                                 once in the registration bundle (Hanka
#                                 keeps only the public half)
#
# Plus your own deployment values:
#   EDC_PUBLIC_HOST               e.g. edc.your-domain.com — must resolve to this host
#   ACME_EMAIL                    Let's Encrypt notification address
# =============================================================================

EDC_VERSION=0.12.0

# --- Public hostname for this connector ---
EDC_PUBLIC_HOST=
ACME_EMAIL=

# --- Identity (provided by the Hanka operator) ---
EDC_BPN=
EDC_DID=

# --- Participant context ID (UUID, mandatory since EDC 0.12.0) ---
# Generate with: uuidgen
EDC_PARTICIPANT_CONTEXT_ID=

# --- DSP / data-plane URLs advertised to peers ---
# Replace <YOUR_HOST> with the same value as EDC_PUBLIC_HOST.
EDC_DSP_CALLBACK_ADDRESS=https://<YOUR_HOST>/api/v1/dsp
EDC_DATAPLANE_PUBLIC_URL=https://<YOUR_HOST>/api/public

EDC_HOSTNAME=controlplane

# --- Hanka operator endpoints (public) ---
STS_TOKEN_URL=https://identityhub.hanka.ai/api/sts/token
# Replace <BASE64_BPN> with the base64 (no padding) of your BPN once you have it.
#   echo -n "$EDC_BPN" | base64 | tr -d '='
CREDENTIAL_SERVICE_URL=https://identityhub.hanka.ai/api/credentials/v1/participants/<BASE64_BPN>
BDRS_URL=https://bdrs.hanka.ai/api/directory
TRUSTED_ISSUER_DID=did:web:identityhub.hanka.ai:BPNL00000003CRHK

# --- Secrets (provided by the Hanka operator) ---
STS_CLIENT_SECRET=
TOKEN_SIGNER_KEY_JWK=

# --- Local infrastructure ---
# setup.sh fills POSTGRES_PASSWORD and EDC_API_KEY with strong random values.
POSTGRES_USER=edc
POSTGRES_PASSWORD=
EDC_API_KEY=

EDC_TOKEN_PERIOD=720h
EDC_MANAGEMENT_HOST_PORT=29181

JAVA_TOOL_OPTIONS=-Xmx512m
