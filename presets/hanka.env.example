# =============================================================================
# Preset: Hanka  —  https://hanka.ai
#
# Register your connector in the Hanka portal (Services -> EDC -> Connectors
# -> Company-managed): enter a name and your public hostname, and the portal
# returns a bundle whose values fill everything below.
#
# Everything else — ports, image versions, JVM sizing, the DSP / data-plane
# URLs advertised to peers — has working defaults. See "Optional overrides"
# at the bottom.
# =============================================================================

# --- Your deployment ---
# Public hostname for this connector (the DNS record must point at this host).
EDC_PUBLIC_HOST=
# Let's Encrypt notification email — used only by the bundled Caddy. Leave
# empty if you terminate TLS at your own proxy (ONBOARDING §4).
ACME_EMAIL=

# --- Identity (from the Hanka portal bundle) ---
EDC_BPN=
EDC_DID=

# --- Participant context ID (setup.sh generates this) ---
EDC_PARTICIPANT_CONTEXT_ID=

# --- Hanka operator endpoints (from the portal bundle) ---
STS_TOKEN_URL=https://identityhub.hanka.ai/api/sts/token
# <BASE64_BPN> = base64 of your BPN. KEEP the '=' padding — the Identity Hub
# expects it and the portal emits it padded:   echo -n "$EDC_BPN" | base64
CREDENTIAL_SERVICE_URL=https://identityhub.hanka.ai/api/credentials/v1/participants/<BASE64_BPN>
BDRS_URL=https://bdrs.hanka.ai/api/directory
TRUSTED_ISSUER_DID=did:web:identityhub.hanka.ai:BPNL00000003CRHK

# --- Secrets ---
# OAuth client secret from the portal bundle (recoverable from the connector
# detail page if lost).
STS_CLIENT_SECRET=
# setup.sh fills these two with strong random values.
POSTGRES_PASSWORD=
EDC_API_KEY=

# --- Optional overrides (defaults live in docker-compose.yaml) ---------------
# Data-plane signer key: self-generated in vault on first boot; only set to
# bring your own private Ed25519 JWK (ONBOARDING §1.2).
#TOKEN_SIGNER_KEY_JWK=
# Public URLs advertised to peers — derived from EDC_PUBLIC_HOST; override
# only if your edge routes them somewhere non-standard.
#EDC_DSP_CALLBACK_ADDRESS=https://<host>/api/v1/dsp
#EDC_DATAPLANE_PUBLIC_URL=https://<host>/api/public
#EDC_VERSION=0.12.0
#POSTGRES_USER=edc
#EDC_TOKEN_PERIOD=720h
#EDC_MANAGEMENT_HOST_PORT=29181
#JAVA_TOOL_OPTIONS=-Xmx512m
#OTEL_JAVAAGENT_ENABLED=false
